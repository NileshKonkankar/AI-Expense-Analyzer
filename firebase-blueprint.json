{
  "entities": {
    "Expense": {
      "title": "Expense",
      "description": "A financial expense record",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the expense"
        },
        "description": {
          "type": "string",
          "description": "Description of the expense"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense"
        },
        "category": {
          "type": "string",
          "description": "The category of the expense"
        },
        "date": {
          "type": "string",
          "description": "The date of the expense in ISO format"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the expense was created"
        }
      },
      "required": ["userId", "description", "amount", "category", "date", "createdAt"]
    },
    "RecurringExpense": {
      "title": "Recurring Expense",
      "description": "A template for recurring expenses",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the recurring expense"
        },
        "description": {
          "type": "string",
          "description": "Description of the expense"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense"
        },
        "category": {
          "type": "string",
          "description": "The category of the expense"
        },
        "frequency": {
          "type": "string",
          "description": "Frequency of the recurrence: daily, weekly, monthly, yearly"
        },
        "nextDueDate": {
          "type": "string",
          "description": "The next date this expense should be generated in ISO format"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the recurring expense was created"
        }
      },
      "required": ["userId", "description", "amount", "category", "frequency", "nextDueDate", "createdAt"]
    },
    "CategoryRule": {
      "title": "Category Rule",
      "description": "User preference for AI categorization",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "keyword": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "keyword", "category", "createdAt"]
    },
    "BudgetGoal": {
      "title": "Budget Goal",
      "description": "Monthly budget limit for a category",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "amount": {
          "type": "number",
          "description": "The budget limit amount"
        },
        "month": {
          "type": "string",
          "description": "Month in YYYY-MM format"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "category", "amount", "month", "createdAt"]
    },
    "Income": {
      "title": "Income",
      "description": "A financial income record",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who received the income"
        },
        "description": {
          "type": "string",
          "description": "Description of the income source"
        },
        "amount": {
          "type": "number",
          "description": "The amount of the income"
        },
        "category": {
          "type": "string",
          "description": "The category of the income (e.g. Salary, Freelance, Investments, Other)"
        },
        "date": {
          "type": "string",
          "description": "The date of the income in ISO format"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the income record was created"
        }
      },
      "required": ["userId", "description", "amount", "category", "date", "createdAt"]
    },
    "SavingsGoal": {
      "title": "Savings Goal",
      "description": "A financial savings target",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the savings goal"
        },
        "title": {
          "type": "string",
          "description": "The name or title of the savings goal (e.g. Save for travel)"
        },
        "targetAmount": {
          "type": "number",
          "description": "The target to save"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the savings goal was created"
        }
      },
      "required": ["userId", "title", "targetAmount", "createdAt"]
    },
    "UserSetting": {
      "title": "User Setting",
      "description": "Preferences for notifications and alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "emailEnabled": { "type": "boolean" },
        "pushEnabled": { "type": "boolean" },
        "email": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "emailEnabled", "pushEnabled", "email", "updatedAt"]
    },
    "BudgetAlert": {
      "title": "Budget Alert",
      "description": "Logs of triggered budget thresholds to avoid double alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "month": { "type": "string" },
        "threshold": { "type": "number" },
        "triggeredAt": { "type": "timestamp" },
        "amount": { "type": "number" },
        "limit": { "type": "number" },
        "sentEmail": { "type": "boolean" },
        "sentPush": { "type": "boolean" }
      },
      "required": ["userId", "category", "month", "threshold", "triggeredAt", "amount", "limit", "sentEmail", "sentPush"]
    },
    "FCMToken": {
      "title": "FCM Token",
      "description": "Firebase Cloud Messaging token for web push notification routing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "token": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "token", "createdAt"]
    },
    "NotificationLog": {
      "title": "Notification Log",
      "description": "Logs of email and push notifications dispatched for user audits",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "title", "body", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/expenses/{expenseId}": {
      "schema": {
        "$ref": "#/entities/Expense"
      },
      "description": "Expenses created by users"
    },
    "/recurringExpenses/{recurringExpenseId}": {
      "schema": {
        "$ref": "#/entities/RecurringExpense"
      },
      "description": "Recurring expense templates"
    },
    "/categoryRules/{ruleId}": {
      "schema": {
        "$ref": "#/entities/CategoryRule"
      },
      "description": "Custom user rules for categorization"
    },
    "/categoryBudgets/{budgetId}": {
      "schema": {
        "$ref": "#/entities/BudgetGoal"
      },
      "description": "Monthly category budget goals"
    },
    "/incomes/{incomeId}": {
      "schema": {
        "$ref": "#/entities/Income"
      },
      "description": "Incomes earned by users"
    },
    "/savingsGoals/{goalId}": {
      "schema": {
        "$ref": "#/entities/SavingsGoal"
      },
      "description": "Savings goals set by users"
    },
    "/userSettings/{settingId}": {
      "schema": {
        "$ref": "#/entities/UserSetting"
      },
      "description": "Preferences for notifications and alerts"
    },
    "/budgetAlerts/{alertId}": {
      "schema": {
        "$ref": "#/entities/BudgetAlert"
      },
      "description": "A record of triggered budget threshold alerts"
    },
    "/fcmTokens/{tokenId}": {
      "schema": {
        "$ref": "#/entities/FCMToken"
      },
      "description": "Stores user routing tokens for FCM"
    },
    "/notificationLogs/{logId}": {
      "schema": {
        "$ref": "#/entities/NotificationLog"
      },
      "description": "Audit records of sent system disclosures"
    }
  }
}
